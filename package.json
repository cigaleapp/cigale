	"scripts": {
		"dev": "bun --bun vite dev",
		"dev:native": "electron-forge start",
		"codegen": "bun run scripts/download-google-fonts.js && bun run scripts/generate-json-schemas.js && bun run scripts/codegen-filepath-types.ts && bun run scripts/generate-assetlinks.ts",
		"prebuild": "bun run codegen && bun wuchale --clean --sync",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "bun run codegen",
		"dependencies": "bun run scripts/if-local-dev.ts \"bun cap sync\"",
		"precheck": "svelte-kit sync",
		"check": "svelte-check",
		"preknip": "svelte-kit sync && bun wuchale",
		"knip": "knip",
		"format": "prettier --write .",
		"lint": "bunx oxlint && bunx eslint",
		"lintfix": "bunx oxlint --fix && bunx eslint --fix",
		"commit": "gitmoji -c",
		"test": "vitest --coverage.enabled true",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"test:dirty": "bun run scripts/test-dirty.ts",
		"wuchale": "bunx --bun wuchale",
		"all-contributors": "all-contributors --files README.md --files README_FR.md",
		"test:update-fixtures": "playwright test tasks/exports.spec.js --update-snapshots -x --headed && playwright test tasks/dbdump.spec.js --update-snapshots -x --headed "
	},
