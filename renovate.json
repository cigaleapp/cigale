{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["github>gwennlbh/renovate"],
	"prConcurrentLimit": 8,
	"gitIgnoredAuthors": ["41898282+github-actions[bot]@users.noreply.github.com"],
	"packageRules": [
		{
			"description": "Auto-merge updates to linters and formatters",
			"matchDepTypes": ["devDependencies"],
			"matchPackageNames": [
				"eslint",
				"@eslint/*",
				"eslint-*",
				"oxlint",
				"oxlint-*",
				"knip",
				"prettier",
				"prettier-*",
				"lint-staged",
				"svelte-check",
				"typescript-eslint"
			],
			"automerge": true,
			"prPriority": 10
		},
		{
			"description": "Auto-merge patch upgrades (E2E tests should validate that nothing catastrophic happens)",
			"matchUpdateTypes": ["patch"],
			"automerge": true,
			"prPriority": 5
		},
		{
			"description": "Do not auto-merge gradle or gradle-wrapper updates",
			"matchManagers": ["gradle", "gradle-wrapper"],
			"automerge": false,
			"prPriority": -1
		}
	]
}
