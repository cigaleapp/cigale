{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "authors": {
      "type": "array",
      "description": "Les auteurices ayant participé à l'élaboration du protocole",
      "items": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Adresse email",
            "pattern": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
          },
          "name": {
            "type": "string",
            "description": "Prénom Nom"
          }
        },
        "required": [
          "email",
          "name"
        ]
      }
    },
    "id": {
      "type": "string",
      "description": "Identifiant unique pour le protocole. On conseille de mettre une partie qui vous identifie dans cet identifiant, car il doit être globalement unique. Par exemple, mon-organisation.mon-protocole",
      "pattern": "[\\w_]+"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Description, pour aider à comprendre la métadonnée"
          },
          "label": {
            "type": "string",
            "description": "Nom de la métadonnée"
          },
          "mergeMethod": {
            "anyOf": [
              {
                "const": "average",
                "description": "Prendre la moyenne des valeurs"
              },
              {
                "const": "max",
                "description": "Choisir la valeur avec la meilleure confiance, et prendre la plus grande valeur en cas d'ambuiguité"
              },
              {
                "const": "median",
                "description": "Prendre la médiane des valeurs"
              },
              {
                "const": "min",
                "description": "Choisir la valeur avec la meilleure confiance, et prendre la plus petite valeur en cas d'ambuiguité"
              },
              {
                "const": "none",
                "description": "Ne pas fusionner"
              }
            ],
            "description": "Méthode utiliser pour fusionner plusieurs différentes valeurs d'une métadonnée. Notamment utilisé pour calculer la valeur d'une métadonnée sur une Observation à partir de ses images"
          },
          "required": {
            "anyOf": [
              {
                "type": "boolean"
              }
            ],
            "description": "Si la métadonnée est obligatoire"
          },
          "type": {
            "anyOf": [
              {
                "const": "boolean",
                "description": "un booléen (vrai ou faux)"
              },
              {
                "const": "boundingbox",
                "description": "un objet représentant une région rectangulaire au format YOLO, définie par son point central avec `x` et `y`, et sa largeur et hauteur avec `w` et `h`"
              },
              {
                "const": "date",
                "description": "une date"
              },
              {
                "const": "enum",
                "description": "un ensemble de valeur fixes. Utiliser 'options' sur la définition d'une métadonnée pour préciser les valeurs possibles"
              },
              {
                "const": "float",
                "description": "un nombre, potentiellement à virgule"
              },
              {
                "const": "integer",
                "description": "un entier"
              },
              {
                "const": "location",
                "description": "un objet avec deux nombres, `latitude` et `longitude`"
              },
              {
                "const": "string",
                "description": "du texte"
              }
            ]
          },
          "learnMore": {
            "type": "string",
            "description": "Un lien pour en apprendre plus sur ce que cette métadonnée décrit",
            "pattern": "https?:\\/\\/.+"
          },
          "options": {
            "type": "array",
            "description": "Les options valides. Uniquement utile pour une métadonnée de type \"enum\"",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "type": "string",
                  "description": "Description (optionnelle) de cette option"
                },
                "key": {
                  "type": "string",
                  "description": "Identifiant unique pour cette option",
                  "pattern": "[\\w_]+"
                },
                "label": {
                  "type": "string",
                  "description": "Nom de l'option, affichable dans une interface utilisateur"
                },
                "learnMore": {
                  "type": "string",
                  "description": "Lien pour en savoir plus sur cette option de l'énumération en particulier",
                  "pattern": "https?:\\/\\/.+"
                }
              },
              "required": [
                "description",
                "key",
                "label"
              ]
            }
          }
        },
        "required": [
          "description",
          "label",
          "mergeMethod",
          "required",
          "type"
        ]
      }
    },
    "name": {
      "type": "string",
      "description": "Nom du protocole"
    },
    "source": {
      "type": "string",
      "description": "Lien vers un site où l'on peut se renseigner sur ce protocole. Cela peut aussi être simplement un lien de téléchargement direct de ce fichier",
      "pattern": "https?:\\/\\/.+"
    }
  },
  "required": [
    "authors",
    "id",
    "metadata",
    "name",
    "source"
  ]
}