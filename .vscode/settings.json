{
	"biome.enabled": false,
	"cssvar.extensions": ["css", "svelte"],
	"cssvar.files": ["src/routes/style.css"],
	"bun.test.enable": false,
	"iconify.delimiters": ["/"],
	"iconify.includes": ["ph", "ri"],
	"javascript.preferences.importModuleSpecifierEnding": "js",
	"typescript.preferences.importModuleSpecifierEnding": "js",
	"emmet.syntaxProfiles": {
		"html": {
			"compactBooleanAttributes": true
		}
	},
	"githubIssues.queries": [
		{
			"label": "InsectDetective",
			"query": "repo:${owner}/${repository} state:open milestone:InsectDetective"
		},
		{
			"label": "Terraforma 2"	,
			"query": "repo:${owner}/${repository} state:open milestone:Terraforma2"
		},
		{
			"label": "Urgent",
			"query": "repo:${owner}/${repository} state:open field.priority:urgent"
		},
		{
			"label": "Important",
			"query": "repo:${owner}/${repository} state:open field.priority:high"
		},
		{
			"label": "Easy",
			"query": "repo:${owner}/${repository} state:open field.effort:low"
		},
		{
			"label": "All Issues",
			"query": "repo:${owner}/${repository} state:open sort:created-desc"
		},
		{
			"label": "No milestone",
			"query": "repo:${owner}/${repository} state:open no:milestone no:parent-issue"
		}
	],
	"errorLens.excludePatterns": ["**/*.cigaleprotocol.{json,yaml}"]
}
